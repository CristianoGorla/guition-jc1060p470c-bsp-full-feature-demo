# ESP32-P4 LVGL v9.2.2 Optimizations

# LVGL Memory Management (use ESP-IDF heap instead of internal)
CONFIG_LV_MEM_CUSTOM=y

# L2 Cache Size (256KB for smooth 1024x600 refresh)
CONFIG_CACHE_L2_CACHE_256KB=y

# PSRAM Configuration (confirmed 32MB @ 200MHz from logs)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_200M=y

# Heap allocation defaults to PSRAM for large buffers
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384

# PPA (Pixel Processing Accelerator) for rotation
CONFIG_ESP_LCD_PPA_ENABLE=y

# esp_lvgl_port task configuration
CONFIG_LV_PORT_TASK_STACK_SIZE=6144
CONFIG_LV_PORT_TASK_PRIORITY=4
