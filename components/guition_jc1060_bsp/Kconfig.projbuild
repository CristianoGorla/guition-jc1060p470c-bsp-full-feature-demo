menu "Guition JC1060P470C Board Configuration"

    menu "Hardware Peripherals"

        comment "────────────────────────────────────────────────────────────────"
        comment "DISPLAY CONTROLLER (MIPI-DSI)"
        comment "────────────────────────────────────────────────────────────────"

        config BSP_ENABLE_DISPLAY
            bool "▶ Enable JD9165 MIPI-DSI Display (1024x600)"
            default y
            select SPIRAM_SPEED_200M
            select CACHE_L2_CACHE_256KB
            help
                Enable the JD9165 1024x600 MIPI-DSI display controller.
                This option automatically configures SPIRAM to 200MHz and
                L2 cache to 256KB as required for optimal display performance.

        menu "Display Configuration"
            visible if BSP_ENABLE_DISPLAY

            config BSP_DISPLAY_WIDTH
                int "Display width (pixels)"
                default 1024

            config BSP_DISPLAY_HEIGHT
                int "Display height (pixels)"
                default 600

            config BSP_PIN_LCD_BL
                int "Backlight PWM GPIO"
                default 23

            config BSP_LCD_BL_DEFAULT_DUTY
                int "Default backlight brightness (%)"
                default 100
                range 0 100

        endmenu

        comment "────────────────────────────────────────────────────────────────"
        comment "I2C BUS (Required for Touch, Audio, RTC)"
        comment "────────────────────────────────────────────────────────────────"

        config BSP_ENABLE_I2C
            bool "▶ Enable I2C Bus (400kHz)"
            default y
            help
                Enable the I2C bus for peripherals.
                
                REQUIRED FOR:
                  • GT911 Touch Controller
                  • ES8311 Audio Codec
                  • RX8025T Real-Time Clock

        menu "I2C Bus Configuration"
            visible if BSP_ENABLE_I2C

            config BSP_I2C_SDA_GPIO
                int "I2C SDA GPIO (data line)"
                default 7

            config BSP_I2C_SCL_GPIO
                int "I2C SCL GPIO (clock line)"
                default 8

            config BSP_I2C_FREQ_HZ
                int "I2C Frequency (Hz)"
                default 400000
                help
                    100000 = Standard mode (100 kHz)
                    400000 = Fast mode (400 kHz, recommended)

            comment "──────────────────────────────────────────────────────────"
            comment "I2C Peripherals"
            comment "──────────────────────────────────────────────────────────"

            config BSP_ENABLE_TOUCH
                bool "Enable GT911 Touch Controller (5-point capacitive)"
                default y
                depends on BSP_ENABLE_I2C
                help
                    Enable the GT911 capacitive touch controller.
                    Supports up to 5 simultaneous touch points.

            menu "Touch Controller Configuration"
                visible if BSP_ENABLE_TOUCH

                config BSP_TOUCH_I2C_ADDR
                    hex "GT911 I2C Address"
                    default 0x14
                    help
                        I2C address: 0x14 or 0x5D (set by reset sequence)

                config BSP_PIN_TOUCH_RST
                    int "Touch Reset GPIO (USED ONLY at initialization)"
                    default 21
                    help
                        Hardware RESET pin connected to GPIO 21.
                        
                        ⚠️ NOTE: Used ONLY during GT911 initialization.
                        
                        CURRENT BEHAVIOR:
                          • RST sequence executed once at boot
                          • Forces GT911 I2C address to 0x14 (vs 0x5D)
                          • After init, pin is released and unused
                        
                        RESET SEQUENCE (datasheet):
                          1. INT=LOW, RST=LOW (10ms)
                          2. RST=HIGH (5ms)
                          3. INT returns to input mode
                          4. GT911 initializes (50ms)
                        
                        WHY RESET IS NEEDED:
                          • GT911 I2C address is set by INT state during reset
                          • Without reset, address may be wrong (0x5D vs 0x14)
                          • Ensures predictable I2C communication
                        
                        AFTER INITIALIZATION:
                          • Pin is released (no longer driven)
                          • GT911 runs autonomously
                          • No further reset needed during normal operation
                        
                        MAPPING PRESERVED: Keep default 21.

                config BSP_PIN_TOUCH_INT
                    int "Touch Interrupt GPIO (NOT USED - reserved for future)"
                    default 22
                    help
                        Hardware INT pin connected to GPIO 22.
                        
                        ⚠️ NOTE: This pin is CONFIGURED but NOT USED in current implementation.
                        
                        CURRENT BEHAVIOR:
                          • LVGL uses POLLING mode (reads I2C every ~5ms)
                          • Touch data retrieved via periodic timer callback
                          • Pin INT is electrically connected but software-ignored
                        
                        WHY POLLING INSTEAD OF INTERRUPTS:
                          • I2C transactions require task context (cannot run in ISR)
                          • LVGL timer already runs every 5ms (polling is "free")
                          • 5ms latency is imperceptible for touch UI
                          • Simpler code (no ISR→task signaling needed)
                        
                        FUTURE USE:
                          • Low-power implementations (wake-on-touch)
                          • Ultra-responsive touch (ISR triggers I2C read in task)
                        
                        MAPPING PRESERVED: Keep default 22 to maintain hardware compatibility.

                config BSP_TOUCH_MAX_POINTS
                    int "Maximum touch points"
                    default 5
                    range 1 10

            endmenu

            config BSP_ENABLE_AUDIO
                bool "Enable ES8311 Audio Codec + NS4150 Amplifier"
                default n
                depends on BSP_ENABLE_I2C
                help
                    Enable the ES8311 audio codec and NS4150 power amplifier
                    for audio input/output (I2S interface).

            menu "Audio Configuration"
                visible if BSP_ENABLE_AUDIO

                config BSP_AUDIO_CODEC_I2C_ADDR
                    hex "ES8311 Codec I2C Address"
                    default 0x18

                config BSP_PIN_I2S_MCLK
                    int "I2S MCLK GPIO"
                    default 9

                config BSP_PIN_I2S_BCLK
                    int "I2S BCLK GPIO"
                    default 13

                config BSP_PIN_I2S_WS
                    int "I2S WS (LRCK) GPIO"
                    default 12

                config BSP_PIN_I2S_DOUT
                    int "I2S DOUT GPIO"
                    default 10

                config BSP_PIN_PA_ENABLE
                    int "Power Amplifier Enable GPIO"
                    default 11

                config BSP_AUDIO_SAMPLE_RATE
                    int "Default sample rate (Hz)"
                    default 48000

            endmenu

            config BSP_ENABLE_RTC
                bool "Enable RX8025T Real-Time Clock"
                default n
                depends on BSP_ENABLE_I2C
                help
                    Enable the RX8025T real-time clock module
                    with battery backup for accurate timekeeping.

            menu "RTC Configuration"
                visible if BSP_ENABLE_RTC

                config BSP_RTC_I2C_ADDR
                    hex "RX8025T I2C Address"
                    default 0x32

                config BSP_PIN_RTC_INT
                    int "RTC Interrupt GPIO"
                    default 0

            endmenu

            config BSP_ENABLE_CAMERA
                bool "Enable OV02C10 Camera (MIPI CSI-2, 2-lane)"
                default y
                depends on BSP_ENABLE_I2C
                help
                    Enable OV02C10 sensor wrapper support (Phase 1: detection).
                    Initialization includes:
                      - XSHUTDN reset sequence
                      - SCCB/I2C probe and CHIP_ID read
                      - Optional ISP instance registration

            menu "Camera Configuration"
                visible if BSP_ENABLE_CAMERA

                config BSP_PIN_CAMERA_XSHUTDN
                    int "Camera XSHUTDN GPIO"
                    default 20
                    help
                        OV02C10 reset/power-down control pin.
                        Keep mapped to GPIO20 as per board schematic.

                config BSP_PIN_CAMERA_MCLK
                    int "Camera MCLK GPIO"
                    default 5
                    help
                        Camera master clock output pin.

                config BSP_CAMERA_I2C_ADDR
                    hex "Camera SCCB address"
                    default 0x6C
                    help
                        OV02C10 SCCB address as documented in board notes.
                        Driver internally converts to 7-bit format for ESP-IDF I2C.

                config BSP_CAMERA_EXPECTED_CHIP_ID
                    hex "Expected OV02C10 CHIP_ID"
                    default 0x560243

                config ESP_MIPI_CSI_ENABLE
                    bool "Enable MIPI CSI hardware path"
                    default y
                    help
                        Project-level gate used by camera wrapper for CSI bring-up.

                config ESP_ISP_ENABLE
                    bool "Enable hardware ISP pipeline"
                    default y
                    depends on ESP_MIPI_CSI_ENABLE
                    help
                        Enables ISP processor pipeline for RAW input conversion.

                config ESP_ISP_AUTO_AWB
                    bool "Enable ISP auto white balance controller"
                    default y
                    depends on ESP_ISP_ENABLE

                config ESP_ISP_AUTO_AE
                    bool "Enable ISP auto exposure controller"
                    default y
                    depends on ESP_ISP_ENABLE

                config ESP_PPA_ENABLE
                    bool "Enable PPA scaler for camera preview"
                    default y
                    depends on ESP_ISP_ENABLE
                    help
                        Enables PPA hardware scaling path used by OV02C10 preview.

                config BSP_ESP32P4_SILICON_REV_LOWER_3
                    bool "ESP32-P4 Silicon Revision < v3.0"
                    default y
                    help
                        Disabilita i moduli ISP (BLC, WBG) non supportati nelle prime revisioni del silicio (es. v1.3).

                choice BSP_CAMERA_RESOLUTION
                    prompt "Camera default resolution"
                    default BSP_CAMERA_RES_1080P

                    config BSP_CAMERA_RES_1080P
                        bool "1920x1080 (1080p)"

                    config BSP_CAMERA_RES_UXGA
                        bool "1600x1200 (UXGA)"
                endchoice

                config BSP_CAMERA_FRAME_WIDTH
                    int
                    default 1920 if BSP_CAMERA_RES_1080P
                    default 1600 if BSP_CAMERA_RES_UXGA

                config BSP_CAMERA_FRAME_HEIGHT
                    int
                    default 1080 if BSP_CAMERA_RES_1080P
                    default 1200 if BSP_CAMERA_RES_UXGA

                config BSP_CAMERA_DEBUG_SENSOR_TEST_PATTERN
                    bool "Debug: Enable OV02C10 sensor test pattern"
                    default n
                    help
                        Enables the OV02C10 internal test pattern through
                        ESP_CAM_SENSOR_IOC_S_TEST_PATTERN when stream starts.
                        Useful to isolate sensor/ISP/display pipeline issues.
                        Keep disabled for normal operation.

                comment "OV02C10 slim driver compatibility options"

                config CAMERA_OV02C10
                    bool
                    default y

                config CAMERA_OV02C10_MAX_SUPPORT
                    int
                    default 1

                config CAMERA_OV02C10_AUTO_DETECT
                    bool
                    default y

                config CAMERA_OV02C10_AUTO_DETECT_MIPI_INTERFACE_SENSOR
                    bool
                    default y
                    depends on CAMERA_OV02C10_AUTO_DETECT

                choice CAMERA_OV02C10_MIPI_DEFAULT_FMT
                    prompt "OV02C10 default MIPI format"
                    default CAMERA_OV02C10_MIPI_RAW10_1920x1080_2LAN_30FPS

                    config CAMERA_OV02C10_MIPI_RAW10_1288x728_30FPS
                        bool "RAW10 1288x728 30fps"
                    config CAMERA_OV02C10_MIPI_RAW10_1920x1080_30FPS
                        bool "RAW10 1920x1080 30fps (1 lane)"
                    config CAMERA_OV02C10_MIPI_RAW10_1920x1080_2LAN_30FPS
                        bool "RAW10 1920x1080 30fps (2 lanes)"
                endchoice

                config CAMERA_OV02C10_MIPI_IF_FORMAT_INDEX_DAFAULT
                    int
                    default 0 if CAMERA_OV02C10_MIPI_RAW10_1288x728_30FPS
                    default 1 if CAMERA_OV02C10_MIPI_RAW10_1920x1080_30FPS
                    default 2 if CAMERA_OV02C10_MIPI_RAW10_1920x1080_2LAN_30FPS

                config CAMERA_OV02C10_CSI_LINESYNC_ENABLE
                    bool
                    default y

                config CAMERA_OV02C10_ISP_AF_ENABLE
                    bool
                    default n

                config CAMERA_OV02C10_ABSOLUTE_GAIN_LIMIT
                    int
                    default 66016
                    range 4000 126016

                choice CAMERA_OV02C10_ABS_GAIN_MAP_PRIORITY
                    prompt "OV02C10 gain map priority"
                    default CAMERA_OV02C10_ANA_GAIN_PRIORITY

                    config CAMERA_OV02C10_ANA_GAIN_PRIORITY
                        bool "Analog gain priority"
                    config CAMERA_OV02C10_DIG_GAIN_PRIORITY
                        bool "Digital gain priority"
                endchoice

                choice CAMERA_OV02C10_IPA_JSON_CONFIGURATION_FILE
                    prompt "OV02C10 IPA JSON configuration"
                    default CAMERA_OV02C10_DEFAULT_IPA_JSON_CONFIGURATION_FILE

                    config CAMERA_OV02C10_DEFAULT_IPA_JSON_CONFIGURATION_FILE
                        bool "Default"
                    config CAMERA_OV02C10_CUSTOMIZED_IPA_JSON_CONFIGURATION_FILE
                        bool "Customized"
                endchoice

                config CAMERA_OV02C10_CUSTOMIZED_IPA_JSON_CONFIGURATION_FILE_PATH
                    string "OV02C10 customized JSON configuration file path"
                    depends on CAMERA_OV02C10_CUSTOMIZED_IPA_JSON_CONFIGURATION_FILE

                comment "MIPI CSI-2 data lanes: 2 (hardware fixed, board pins 42-48)"

            endmenu

        endmenu # I2C Bus Configuration

