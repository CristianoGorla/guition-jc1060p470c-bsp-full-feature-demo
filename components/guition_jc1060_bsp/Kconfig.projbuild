    comment "════════════════════════════════════════════════════════════════════"

    menu "LVGL Graphics Library (v9.2.2)"
        config BSP_ENABLE_LVGL
            bool "▶ Enable LVGL Graphics Library"
            default y
            depends on BSP_ENABLE_DISPLAY

        menu "Display Buffer Configuration"
            visible if BSP_ENABLE_LVGL
            config BSP_LVGL_BUFFER_LINES
                int "Buffer size (lines)"
                default 100
                range 10 300
            config BSP_LVGL_DOUBLE_BUFFER
                bool "Enable double buffering"
                default y
            config BSP_LVGL_USE_DMA_BUFFER
                bool "Use DMA-capable buffers"
                default y
            config BSP_LVGL_USE_SPIRAM_BUFFER
                bool "Use SPIRAM for buffers"
                default n
        endmenu

        menu "Display Rotation"
            visible if BSP_ENABLE_LVGL
            config BSP_LVGL_ENABLE_SW_ROTATE
                bool "Enable software rotation"
                default y
            choice BSP_LVGL_ROTATION
                prompt "Initial rotation"
                default BSP_LVGL_ROTATION_0
                depends on BSP_LVGL_ENABLE_SW_ROTATE
                config BSP_LVGL_ROTATION_0
                    bool "0°"
                config BSP_LVGL_ROTATION_90
                    bool "90°"
                config BSP_LVGL_ROTATION_180
                    bool "180°"
                config BSP_LVGL_ROTATION_270
                    bool "270°"
            endchoice
            config BSP_LVGL_ROTATION_DEGREE
                int
                default 0 if BSP_LVGL_ROTATION_0
                default 90 if BSP_LVGL_ROTATION_90
                default 180 if BSP_LVGL_ROTATION_180
                default 270 if BSP_LVGL_ROTATION_270
        endmenu

        menu "Touch Input Integration"
            visible if BSP_ENABLE_LVGL && BSP_ENABLE_I2C && BSP_ENABLE_TOUCH
            config BSP_LVGL_TOUCH_ENABLE
                bool "Enable touch input"
                default y
        endmenu

        menu "Demo Applications"
            visible if BSP_ENABLE_LVGL
            config BSP_LVGL_ENABLE_DEMO
                bool "Enable demo at startup"
                default n
            choice BSP_LVGL_DEMO_TYPE
                prompt "Demo type"
                default BSP_LVGL_DEMO_SIMPLE
                depends on BSP_LVGL_ENABLE_DEMO
                config BSP_LVGL_DEMO_SIMPLE
                    bool "Simple test screen"
                config BSP_LVGL_DEMO_WIDGETS
                    bool "Widgets showcase"
                config BSP_LVGL_DEMO_BENCHMARK
                    bool "Benchmark"
                config BSP_LVGL_DEMO_STRESS
                    bool "Stress test"
            endchoice
        endmenu
    endmenu

    comment "════════════════════════════════════════════════════════════════════"

    menu "Power Management"
        config BSP_ENABLE_HARD_RESET
            bool "Enable hard reset on crash"
            default y
        config BSP_HARD_RESET_DISCHARGE_MS
            int "Reset discharge time (ms)"
            depends on BSP_ENABLE_HARD_RESET
            default 500
        config BSP_POWER_STABILIZATION_MS
            int "Power stabilization delay (ms)"
            default 100
    endmenu

    comment "════════════════════════════════════════════════════════════════════"

    menu "Application Features"
        config APP_ENABLE_NVS
            bool "Enable NVS"
            default y

        config BSP_SENSORS_LOG_UPTIME_TEMP
            bool "Enable uptime log with temperature"
            default n
            help
                When enabled, the application logs every 5 seconds using the
                format: "SYSTEM: Uptime: %llds | Temp: %.2f C".
                Temperature comes from AHT20/BMP280 on shared I2C0, with TSENS
                fallback when I2C sensors are not detected.

        config APP_ENABLE_WIFI_CONNECT
            bool "WiFi auto-connect"
            default y
            depends on BSP_ENABLE_WIFI
        config APP_ENABLE_RTC_NTP_SYNC
            bool "RTC NTP sync"
            default y
            depends on BSP_ENABLE_I2C && BSP_ENABLE_RTC && APP_ENABLE_WIFI_CONNECT
        menu "NTP Sync Configuration"
            visible if APP_ENABLE_RTC_NTP_SYNC
            config APP_NTP_SYNC_TIMEOUT_SEC
                int "Timeout (seconds)"
                default 60
            config APP_NTP_DEBUG_ENABLE
                bool "Debug logging"
                default n
        endmenu

        menu "Log Output Filtering"

            config APP_REDUCE_EXTERNAL_LOG_NOISE
                bool "Reduce external library log noise"
                default n
                help
                    When enabled, the app lowers log level for selected external
                    tags (for example jd9165, GT911, LVGL*) so BSP panel logs stay
                    as the primary runtime output.

            choice APP_EXTERNAL_LOG_FILTER_LEVEL
                prompt "Filtered external log level"
                depends on APP_REDUCE_EXTERNAL_LOG_NOISE
                default APP_EXTERNAL_LOG_FILTER_WARN

                config APP_EXTERNAL_LOG_FILTER_WARN
                    bool "Warnings and errors"

                config APP_EXTERNAL_LOG_FILTER_ERROR
                    bool "Errors only"

                config APP_EXTERNAL_LOG_FILTER_NONE
                    bool "Silent (no logs)"
            endchoice

        endmenu
    endmenu

    comment "════════════════════════════════════════════════════════════════════"

    menu "Debug Logging (Development)"

        config BSP_ENABLE_DEBUG_MODE
            bool "Enable BSP debug mode"
            default n
            help
                Master switch for BSP debug features and optional boot-time
                hardware validation tests. Keep disabled for production builds.

        menu "Hardware Tests"
            visible if BSP_ENABLE_DEBUG_MODE

            config APP_ENABLE_RTC_TEST
                bool "RTC test on boot"
                default n
                depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_I2C && BSP_ENABLE_RTC

            config APP_ENABLE_SD_TEST
                bool "SD card test on boot"
                default n
                depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_SDCARD

            config APP_ENABLE_WIFI_SCAN_TEST
                bool "WiFi scan test on boot"
                default n
                depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_WIFI

        endmenu

        config BSP_ENABLE_HEARTBEAT
            bool "Enable system heartbeat monitoring"
            default n
            depends on BSP_ENABLE_DEBUG_MODE
            help
                Enable background task that logs system uptime and memory stats.
                Useful for debugging to verify ESP32-P4 is responsive and detect memory leaks.
                Creates a low-priority FreeRTOS task that runs independently.

                Disable in production to reduce log verbosity and save minimal resources.

        config BSP_HEARTBEAT_INTERVAL_MS
            int "Heartbeat log interval (milliseconds)"
            depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_HEARTBEAT
            default 5000
            range 1000 60000
            help
                Time interval between heartbeat log messages.
                Default: 5000ms (5 seconds)
                Range: 1-60 seconds

        config BSP_HEARTBEAT_TASK_PRIORITY
            int "Heartbeat task priority"
            depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_HEARTBEAT
            default 1
            range 0 10
            help
                FreeRTOS task priority for heartbeat monitoring.
                Lower value = lower priority (less CPU time).
                Default: 1 (very low priority, runs only when system is idle)

        config BSP_HEARTBEAT_TASK_STACK_SIZE
            int "Heartbeat task stack size (bytes)"
            depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_HEARTBEAT
            default 2048
            range 1024 4096
            help
                Stack size allocated for heartbeat task.
                Default: 2048 bytes (sufficient for logging only)

        comment "--------------------------------------------------------------"
        comment "Display & LVGL Debug"
        comment "--------------------------------------------------------------"

        config DEBUG_DISPLAY_AGGRESSIVE
            bool "⚠️  Enable aggressive display driver logging"
            default n
            depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_DISPLAY
            help
                Enable deep debugging for JD9165 display driver:
                
                LOGS INCLUDE:
                  • Every MIPI-DSI command sent (with hex data)
                  • Timing delays between commands
                  • Backlight PWM changes
                  • Panel initialization sequence
                  • Memory allocations for display buffers
                
                ⚠️ WARNING:
                  - HIGH OVERHEAD: May reduce FPS
                  - VERBOSE: Generates large serial output
                  - Use ONLY for display init debugging
                
                Disable for production builds.

        config DEBUG_LVGL_AGGRESSIVE
            bool "⚠️  Enable aggressive LVGL rendering logging"
            default n
            depends on BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_LVGL
            help
                Enable deep debugging for LVGL v9 rendering:
                
                LOGS INCLUDE:
                  • Every flush_cb() call with dirty area coordinates
                  • Buffer addresses (PSRAM vs DRAM detection)
                  • Buffer allocation sizes
                  • Display/Touch driver registration
                  • LVGL task creation
                  • Frame timing (microseconds)
                
                ⚠️ WARNING:
                  - HIGH OVERHEAD: Serial output slows rendering
                  - May cause apparent "lag" due to logging
                  - Use ONLY for render pipeline debugging
                
                Disable for production builds.

        menu "I2C Debug & Testing"
            visible if BSP_ENABLE_DEBUG_MODE && BSP_ENABLE_I2C

            config DEBUG_I2C_GPIO_CHECK
                bool "Enable I2C GPIO state check (detects MIPI-DSI conflict)"
                default n
                depends on BSP_ENABLE_DEBUG_MODE
                help
                    Check GPIO SDA/SCL levels after display initialization.
                    Detects if MIPI-DSI has disrupted I2C bus (GPIO stuck LOW).
                    
                    Documented in: docs/I2C_MIPI_DSI_CONFLICT.md
                    
                    LOGS:
                      • GPIO levels (SDA, SCL)
                      • Fault detection (stuck LOW warning)
                    
                    Overhead: Minimal (one-time check)
                    Safe for production use.

            config DEBUG_I2C_AUTO_RECOVERY
                bool "Enable automatic I2C bus recovery"
                default n
                depends on BSP_ENABLE_DEBUG_MODE && DEBUG_I2C_GPIO_CHECK
                help
                    Automatically reinitialize I2C bus if GPIO fault detected.
                    
                    RECOVERY SEQUENCE:
                      1. Delete existing I2C bus
                      2. Reset GPIO pins (SDA, SCL)
                      3. Re-create I2C bus with Kconfig settings
                      4. Verify GPIO state after recovery
                    
                    Documented in: docs/I2C_MIPI_DSI_CONFLICT.md
                    
                    Requires DEBUG_I2C_GPIO_CHECK=y.
                    Safe for production use.

            config DEBUG_I2C_TEST_PERIPHERALS
                bool "Test I2C peripherals on boot"
                default n
                depends on BSP_ENABLE_DEBUG_MODE
                help
                    Test configured I2C peripherals during boot:
                      • GT911 Touch (0x14) - if BSP_ENABLE_TOUCH
                      • ES8311 Audio (0x18) - if BSP_ENABLE_AUDIO
                      • RX8025T RTC (0x32) - if BSP_ENABLE_RTC
                    
                    Uses targeted probing, NOT generic scan.
                    
                    LOGS:
                      • [0xADDR] ✓ Device Name (if responding)
                      • [0xADDR] ✗ Device NOT responding (if failed)
                      • Total devices found
                    
                    Safe for production use.

            config BSP_SENSOR_DETAILED_BOOT_LOGS
                bool "Detailed sensor boot logs (AHT20/BMP280)"
                default n
                depends on BSP_ENABLE_DEBUG_MODE
                help
                    Enable detailed per-address sensor probe logs during boot
                    for the AHT20/BMP280 sensor layer.

                    When disabled, the sensor layer keeps startup output
                    compact and only reports summary/warnings.

            config DEBUG_I2C_VERBOSE
                bool "⚠️  Verbose I2C transaction logging"
                default n
                depends on BSP_ENABLE_DEBUG_MODE
                help
                    Enable verbose logging in ESP-IDF I2C driver.
                    
                    LOGS INCLUDE:
                      • Every I2C read/write transaction
                      • Transaction timing and delays
                      • Detailed error information
                    
                    ⚠️ WARNING:
                      - VERY HIGH OVERHEAD
                      - Floods serial output (100+ Hz with touch polling)
                      - May hide useful logs in flood
                    
                    Disable for production builds.

        endmenu # I2C Debug & Testing

        config DEBUG_LOG_LEVEL_VERBOSE
            bool "Set global log level to VERBOSE (ESP_LOG_VERBOSE)"
            default n
            depends on BSP_ENABLE_DEBUG_MODE
            help
                Override ESP-IDF log level to VERBOSE to see TRACE macros.
                Required if you want to see DISP_TRACE() and LVGL_TRACE().
                
                Normal operation: INFO level is sufficient.

    endmenu # Debug Logging

endmenu # Guition JC1060P470C Board Configuration
